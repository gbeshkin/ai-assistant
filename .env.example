APP_NAME=Tallinn AI Assistant v2
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=*

# openai | ollama
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.3
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_TIMEOUT_SECONDS=120
ENABLE_AUDIO=true

# Ollama (optional alternative provider)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=120

AUDIO_OUTPUT_DIR=./output/audio

SYSTEM_PROMPT_RU=Ты цифровой помощник горуправы Таллинна. Отвечай кратко, понятно и по делу. Если не уверен, прямо скажи об этом.
SYSTEM_PROMPT_ET=Sa oled Tallinna linnavalitsuse digitaalne assistent. Vasta lühidalt, selgelt ja konkreetselt. Kui sa ei ole kindel, ütle seda otse.
SYSTEM_PROMPT_EN=You are a digital assistant for Tallinn city administration. Answer clearly, briefly, and directly. If you are unsure, say so plainly.
